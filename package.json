{
  "name": "website",
  "version": "1.0.0",
  "main": "index.js",
  "repository": "https://github.com/studioember/website",
  "author": "Nathan Grey",
  "license": "MIT",
  "private": true,
  "type": "module",
  "dependencies": {
    "@11ty/eleventy": "4.0.0-alpha.6",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-navigation": "^1.0.4",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@tailwindcss/cli": "^4.1.12",
    "moment": "^2.30.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.12",
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.12"
  },
  "scripts": {
    "dev": "yarn run dev:eleventy & yarn run dev:css",
    "dev:css": "yarn tailwindcss -i ./frameworks/tailwind/tailwind.css -o ./assets/css/generated/tailwind.css --watch --content \"./**/*.{njk,liquid,html,md}\"",
    "dev:eleventy": "eleventy --serve",
    "build": "yarn build:css && yarn build:eleventy && yarn prettier --write \"output/site/**/*.html\"",
    "build:css": "yarn tailwindcss -i ./frameworks/tailwind/tailwind.css -o ./assets/css/generated/tailwind.css --minify --content \"./**/*.{njk,liquid,html,md}\"",
    "build:eleventy": "eleventy",
    "format:html": "prettier --write 'output/site/**/*.html'"
  }
}
