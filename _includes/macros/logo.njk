{% macro logo(iconHeight="h-14", textHeight="h-16") %}
  {# Icon: dark variant in light mode, light variant in dark mode #}
  <img src="/assets/img/logo-small-dark.png" alt="Grey Wellness" class="{{ iconHeight }} w-auto dark-hidden" loading="lazy" decoding="async" />
  <img src="/assets/img/logo-small-light.png" alt="" class="{{ iconHeight }} w-auto dark-block" loading="lazy" decoding="async" aria-hidden="true" />
  {# Text: dark variant in light mode, light variant in dark mode #}
  <img src="/assets/img/logo-text-dark.png" alt="" class="{{ textHeight }} w-auto dark-hidden" loading="lazy" decoding="async" aria-hidden="true" />
  <img src="/assets/img/logo-text-light.png" alt="" class="{{ textHeight }} w-auto dark-block" loading="lazy" decoding="async" aria-hidden="true" />
{% endmacro %}
