{% macro googleForm(formResponseId, fields, uid="gf", submitLabel="Submit", successTitle="You're on the list!", successBody="We'll be in touch.") %}
<form id="gf-{{ uid }}-form" class="max-w-sm space-y-4">
{% for field in fields %}{% set fieldId = "gf-" + uid + "-" + loop.index0 %}
<div>
<label class="block text-sm font-medium text-foreground mb-1" for="{{ fieldId }}">{{ field.label }}</label>
{% if field.type == "textarea" %}<textarea id="{{ fieldId }}" data-gf-entry="{{ field.entry }}" {{ "required" if field.required }} rows="4" class="w-full rounded-md border border-border bg-background px-4 py-2.5 text-sm text-foreground placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-primary" placeholder="{{ field.placeholder }}"></textarea>{% else %}<input id="{{ fieldId }}" type="{{ field.type }}" data-gf-entry="{{ field.entry }}" {{ "required" if field.required }} class="w-full rounded-md border border-border bg-background px-4 py-2.5 text-sm text-foreground placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-primary" placeholder="{{ field.placeholder }}">{% endif %}
</div>
{% endfor %}
<div class="cf-turnstile" data-sitekey="0x4AAAAAAC_XnSI6qqVsURDh" data-theme="auto"></div>
<p id="gf-{{ uid }}-ts-error" class="hidden text-sm text-red-500">Please complete the verification above.</p>
<button type="submit" class="w-full px-6 py-3 rounded-md bg-primary text-primary-foreground text-sm font-semibold tracking-wide uppercase hover:opacity-90 transition-opacity">{{ submitLabel }}</button>
</form>
<div id="gf-{{ uid }}-success" class="hidden mt-6">
<p class="text-foreground font-semibold text-lg">{{ successTitle }}</p>
<p class="text-muted text-sm mt-1">{{ successBody }}</p>
</div>
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
<script defer src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>
<script>
  (() => {
    const isLocal = ['localhost', '127.0.0.1', ''].includes(window.location.hostname);
    const form = document.getElementById('gf-{{ uid }}-form');
    const success = document.getElementById('gf-{{ uid }}-success');
    const tsError = document.getElementById('gf-{{ uid }}-ts-error');
    const tsWidget = form.querySelector('.cf-turnstile');
    if (!form) return;
    if (isLocal && tsWidget) tsWidget.style.display = 'none';
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      if (!isLocal) {
        const tsInput = form.querySelector('[name="cf-turnstile-response"]');
        if (!tsInput || !tsInput.value) {
          if (tsError) tsError.classList.remove('hidden');
          return;
        }
        if (tsError) tsError.classList.add('hidden');
      }
      const data = new FormData();
      form.querySelectorAll('[data-gf-entry]').forEach(function(el) {
        data.append(el.dataset.gfEntry, el.value);
      });
      fetch('https://docs.google.com/forms/d/e/{{ formResponseId }}/formResponse', {
        method: 'POST',
        mode: 'no-cors',
        body: data
      });
      form.classList.add('hidden');
      success.classList.remove('hidden');
      if (typeof confetti === 'function') {
        confetti({ particleCount: 120, spread: 80, origin: { y: 0.6 } });
      }
    });
  })();
</script>
{% endmacro %}
