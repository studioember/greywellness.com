{% from "macros/contact-button.njk" import contactButton %}
{% block footer %}
  {# Resolve locale-specific data for this render #}
  {% set _lang = lang | default("en") %}
  {% set _t = i18n[_lang] %}

  <footer class="border-t border-border bg-surface">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 py-10">
      <div class="grid gap-8 md:grid-cols-3">
        <div class="space-y-3">
          <div class="flex items-center gap-3 text-lg font-semibold font-logo text-foreground">
            <img src="{{ '/assets/img/ISOLOGO_2_500PX.png' | url }}" alt="Grey Wellness logo" class="h-8 w-auto" width="32" height="32" loading="lazy" decoding="async" />
            <span>Grey Wellness</span>
          </div>
          <p class="text-sm text-muted">
            {{ _t.footer_tagline }}
          </p>
          <div class="inline-block px-4 py-2 text-sm font-medium tracking-wide uppercase bg-primary text-primary-foreground rounded-md hover:opacity-90 transition-opacity">
            {{ contactButton(text=_t.footer_send_message) }}
          </div>
        </div>
        <div class="space-y-3">
          <p class="text-sm font-semibold text-foreground">{{ _t.footer_contact_label }}</p>
          <ul class="space-y-2 text-sm text-muted">
            <li>7315 Wisconsin Avenue, Suite 400W<br>Bethesda MD 20814</li>
            <li><a href="tel:+12402038879" class="hover:text-primary transition-colors">Office: 240-203-8879</a></li>
            <li class="hover:text-primary transition-colors">Fax: 240-627-2513</li>
            <li><a href="mailto:contact@greywellness.com?subject=Inquiry" class="hover:text-primary transition-colors">contact@greywellness.com</a></li>
          </ul>
        </div>
        <div class="space-y-3">
          <p class="text-sm font-semibold text-foreground">{{ _t.footer_company }}</p>
          <ul class="space-y-2 text-sm text-muted">
            <li>
              <a href="{{ '/en/pages/about/' | locale_url | url }}" class="hover:text-primary transition-colors">{{ _t.footer_about }}</a>
            </li>
            <li>
              <a href="{{ '/en/pages/services/' | locale_url | url }}" class="hover:text-primary transition-colors">{{ _t.footer_services }}</a>
            </li>
          </ul>
        </div>
      </div>
      <div class="mt-10 flex flex-col gap-2 border-t border-border pt-6 text-xs text-muted sm:flex-row sm:items-center sm:justify-between">
        <p>© <span data-footer-year></span> Grey Wellness LLC. {{ _t.footer_rights }}</p>
        <p>{{ _t.footer_built_with }}</p>
      </div>
    </div>
  </footer>
  <script>
    (() => {
      const year = document.querySelector("[data-footer-year]");
      if (year) year.textContent = new Date().getFullYear();
    })();
  </script>
{% endblock %}
