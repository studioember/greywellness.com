{% block footer %}
  <footer class="border-t border-border mt-16">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 py-10">
      <div class="grid gap-8 md:grid-cols-3">
        <div class="space-y-3">
          <div class="flex items-center gap-3 text-lg font-semibold font-logo text-foreground">
            <img src="/assets/img/logo-clear-small.png" alt="Studio Ember logo" class="h-8 w-auto" width="32" height="32" loading="lazy" decoding="async" />
            <span>Studio Ember</span>
          </div>
          <p class="text-sm text-muted">
            Independent studio focused on thoughtful software, resilient systems, and long-term partnerships.
          </p>
        </div>
        <div class="space-y-3">
          <p class="text-sm font-semibold text-foreground">Contact</p>
          <ul class="space-y-2 text-sm text-muted">
            <li>
              <a href="/contact/" class="hover:text-primary transition-colors">Start a project</a>
            </li>
            <li>
              <a href="/services/" class="hover:text-primary transition-colors">Services</a>
            </li>
            <li>
              <a href="/posts/" class="hover:text-primary transition-colors">Posts</a>
            </li>
          </ul>
        </div>
        <div class="space-y-3">
          <p class="text-sm font-semibold text-foreground">Company</p>
          <ul class="space-y-2 text-sm text-muted">
            <li>
              <a href="/cloud-sovereignty/" class="hover:text-primary transition-colors">Cloud sovereignty</a>
            </li>
            <li>
              <span>Remote-first</span>
            </li>
            <li>
              <span>United States</span>
            </li>
          </ul>
        </div>
      </div>
      <div class="mt-10 flex flex-col gap-2 border-t border-border pt-6 text-xs text-muted sm:flex-row sm:items-center sm:justify-between">
        <p>© <span data-footer-year></span> Studio Ember. All rights reserved.</p>
        <p>Built with Eleventy and Tailwind.</p>
      </div>
    </div>
  </footer>
  <script>
    (() => {
      const year = document.querySelector("[data-footer-year]");
      if (year) year.textContent = new Date().getFullYear();
    })();
  </script>
{% endblock %}
