{% block footer %}
  <footer class="border-t border-border mt-16">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 py-10">
      <div class="grid gap-8 md:grid-cols-3">
        <div class="space-y-3">
          <div class="flex items-center gap-3 text-lg font-semibold font-logo text-foreground">
            <img src="/assets/img/ISOLOGO_2_500PX.png" alt="Grey Wellness logo" class="h-8 w-auto" width="32" height="32" loading="lazy" decoding="async" />
            <span>Grey Wellness</span>
          </div>
          <p class="text-sm text-muted">
            Holistic wellness rooted in balance, intention, and lasting well-being.
          </p>
        </div>
        <div class="space-y-3">
          <p class="text-sm font-semibold text-foreground">Contact</p>
          <ul class="space-y-2 text-sm text-muted">
            <li>
              <a href="/pages/contact/" class="hover:text-primary transition-colors">Schedule a Consultation</a>
            </li>
            <li>
              <a href="/pages/services/" class="hover:text-primary transition-colors">Services</a>
            </li>
          </ul>
        </div>
        <div class="space-y-3">
          <p class="text-sm font-semibold text-foreground">Company</p>
          <ul class="space-y-2 text-sm text-muted">
            <li>
              <a href="/pages/about/" class="hover:text-primary transition-colors">About Us</a>
            </li>
          </ul>
        </div>
      </div>
      <div class="mt-10 flex flex-col gap-2 border-t border-border pt-6 text-xs text-muted sm:flex-row sm:items-center sm:justify-between">
        <p>© <span data-footer-year></span> Grey Wellness LLC. All rights reserved.</p>
        <p>Built with Eleventy and Tailwind.</p>
      </div>
    </div>
  </footer>
  <script>
    (() => {
      const year = document.querySelector("[data-footer-year]");
      if (year) year.textContent = new Date().getFullYear();
    })();
  </script>
{% endblock %}
