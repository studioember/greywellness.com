{% block navigation %}
  <navigation class="block bg-[#31272d]">
    <nav class="flex items-center h-14 md:h-20 max-w-7xl mx-auto px-4 md:pr-8 md:pl-0">
      <a href="{{ '/' | url }}" class="flex items-center hover:opacity-80 transition-opacity shrink-0">
        {# Mobile: icon only #}
        <img src="{{ '/assets/img/logo-small.png' | url }}" alt="Grey Wellness logo" class="h-10 w-auto md:hidden" loading="lazy" decoding="async" />
        {# Desktop: full logo #}
        <img src="{{ '/assets/img/logo.png' | url }}" alt="Grey Wellness logo" class="h-34 w-auto hidden md:block" loading="lazy" decoding="async" />
      </a>
      <div class="flex-1"></div>

      {# Desktop nav items #}
      <div class="hidden md:flex items-center gap-8">
        <div class="relative">
          <button
            type="button"
            class="flex items-center gap-1.5 text-sm font-medium text-white/70 hover:text-white transition-colors tracking-wide uppercase"
            aria-haspopup="true"
            aria-expanded="false"
            data-pages-toggle
          >
            <span>Explore</span>
            <svg class="h-3.5 w-3.5 mt-0.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path
                fill-rule="evenodd"
                d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.168l3.71-3.938a.75.75 0 1 1 1.08 1.04l-4.24 4.5a.75.75 0 0 1-1.08 0l-4.24-4.5a.75.75 0 0 1 .02-1.06z"
                clip-rule="evenodd"
              />
            </svg>
          </button>
          <div
            class="absolute right-0 z-20 mt-3 hidden w-48 rounded-lg border border-white/10 bg-[#31272d] shadow-xl ring-1 ring-black/10"
            data-pages-menu
          >
            <ul class="py-1.5">
              {% for page in collections.pages %}
                <li>
                  <a
                    href="{{ page.url | url }}"
                    class="block px-4 py-2.5 text-sm text-white/70 hover:text-white hover:bg-white/8 transition-colors"
                  >
                    {{ page.data.title or page.fileSlug }}
                  </a>
                </li>
              {% endfor %}
            </ul>
          </div>
        </div>

        <a
          href="https://monicagrey.clientsecure.me"
          class="px-4 py-2 text-sm font-medium tracking-wide uppercase bg-[#DBA20D] text-[#31272d] rounded-md hover:opacity-90 transition-opacity"
          data-spwidget-scope-id="91b66555-a746-4aaf-97af-68173f0eab96"
          data-spwidget-scope-uri="monicagrey"
          data-spwidget-application-id="7c72cb9f9a9b913654bb89d6c7b4e71a77911b30192051da35384b4d0c6d505b"
          data-spwidget-scope-global
          data-spwidget-autobind
        >
          Schedule
        </a>
      </div>

      {# Mobile nav items #}
      <div class="flex md:hidden items-center gap-2">
        <a
          href="https://monicagrey.clientsecure.me"
          class="px-3 py-1.5 text-xs font-medium tracking-wide uppercase bg-[#DBA20D] text-[#31272d] rounded-md hover:opacity-90 transition-opacity whitespace-nowrap"
        >
          Schedule
        </a>
        <button
          type="button"
          class="flex items-center justify-center w-9 h-9 text-white/70 hover:text-white transition-colors rounded-md hover:bg-white/8"
          aria-label="Open menu"
          aria-expanded="false"
          data-mobile-toggle
        >
          <svg class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" data-mobile-open-icon>
            <path fill-rule="evenodd" d="M2 4.75A.75.75 0 0 1 2.75 4h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 4.75ZM2 10a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 10Zm0 5.25a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd" />
          </svg>
          <svg class="w-5 h-5 hidden" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" data-mobile-close-icon>
            <path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
          </svg>
        </button>
      </div>
    </nav>

    {# Mobile dropdown menu #}
    <div class="hidden md:hidden border-t border-white/10" data-mobile-menu>
      <ul class="py-2 px-4">
        {% for page in collections.pages %}
          <li>
            <a
              href="{{ page.url | url }}"
              class="block py-3 text-sm text-white/70 hover:text-white transition-colors border-b border-white/5 last:border-0"
            >
              {{ page.data.title or page.fileSlug }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </div>
  </navigation>

  <script>
    (() => {
      // Desktop: Explore dropdown
      const toggle = document.querySelector("[data-pages-toggle]");
      const menu = document.querySelector("[data-pages-menu]");
      if (toggle && menu) {
        const closeMenu = () => {
          menu.classList.add("hidden");
          toggle.setAttribute("aria-expanded", "false");
        };
        const openMenu = () => {
          menu.classList.remove("hidden");
          toggle.setAttribute("aria-expanded", "true");
        };
        toggle.addEventListener("click", (e) => {
          e.preventDefault();
          menu.classList.contains("hidden") ? openMenu() : closeMenu();
        });
        document.addEventListener("click", (e) => {
          if (!menu.contains(e.target) && !toggle.contains(e.target)) closeMenu();
        });
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape") closeMenu();
        });
      }

      // Mobile: hamburger menu
      const mobileToggle = document.querySelector("[data-mobile-toggle]");
      const mobileMenu = document.querySelector("[data-mobile-menu]");
      const openIcon = document.querySelector("[data-mobile-open-icon]");
      const closeIcon = document.querySelector("[data-mobile-close-icon]");
      if (mobileToggle && mobileMenu) {
        mobileToggle.addEventListener("click", () => {
          const isOpen = !mobileMenu.classList.contains("hidden");
          mobileMenu.classList.toggle("hidden");
          mobileToggle.setAttribute("aria-expanded", String(!isOpen));
          openIcon.classList.toggle("hidden");
          closeIcon.classList.toggle("hidden");
        });
      }
    })();
  </script>
{% endblock %}
