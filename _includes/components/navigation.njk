{% block navigation %}
  <navigation class="block bg-[#31272d] sticky top-0 z-50">
    <nav class="flex items-center h-14 md:h-20 max-w-7xl mx-auto px-4 md:pr-8 md:pl-0">
      <a href="{{ '/' | url }}" class="flex items-center hover:opacity-80 transition-opacity shrink-0">
        {# Mobile: icon only #}
        <img src="{{ '/assets/img/logo-small.png' | url }}" alt="Grey Wellness logo" class="h-10 w-auto md:hidden" loading="lazy" decoding="async" />
        {# Desktop: full logo #}
        <img src="{{ '/assets/img/logo.png' | url }}" alt="Grey Wellness logo" class="h-34 w-auto hidden md:block" loading="lazy" decoding="async" />
      </a>
      <div class="flex-1"></div>

      {# Desktop nav items #}
      <div class="hidden md:flex items-center gap-8">
        <a href="{{ '/pages/about/' | url }}" class="text-sm font-medium text-white/70 hover:text-white transition-colors tracking-wide uppercase">About</a>

        {# Services dropdown #}
        <div class="relative" data-dropdown>
          <button
            type="button"
            class="flex items-center gap-1 text-sm font-medium text-white/70 hover:text-white transition-colors tracking-wide uppercase"
            aria-expanded="false"
            data-dropdown-toggle
          >
            Services
            <svg class="w-3.5 h-3.5 mt-0.5 transition-transform" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" data-dropdown-chevron>
              <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
            </svg>
          </button>
          <div class="absolute top-full left-1/2 -translate-x-1/2 mt-2 w-52 rounded-xl bg-[#31272d] border border-white/10 shadow-xl py-1 hidden" data-dropdown-menu>
            <a href="{{ '/pages/services/' | url }}" class="block px-4 py-3 text-sm text-white/70 hover:text-white hover:bg-white/5 transition-colors">
              What We Treat
            </a>
            <a href="{{ '/pages/how-we-work/' | url }}" class="block px-4 py-3 text-sm text-white/70 hover:text-white hover:bg-white/5 transition-colors">
              How We Work
            </a>
            <a href="{{ '/pages/groups/' | url }}" class="block px-4 py-3 text-sm text-white/70 hover:text-white hover:bg-white/5 transition-colors">
              Groups
            </a>
          </div>
        </div>

        <a href="{{ '/pages/investment/' | url }}" class="text-sm font-medium text-white/70 hover:text-white transition-colors tracking-wide uppercase">Investment</a>

        <a
          href="{{ '/pages/contact/' | url }}"
          class="px-4 py-2 text-sm font-medium tracking-wide uppercase bg-[#DBA20D] text-[#31272d] rounded-md hover:opacity-90 transition-opacity"
        >
          Contact
        </a>
        <a
          href="https://monicagrey.clientsecure.me/sign-in"
          class="px-4 py-2 text-sm font-medium tracking-wide uppercase text-white/50 border border-white/20 rounded-md hover:text-white/80 hover:border-white/40 transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          Client Portal
        </a>
      </div>

      {# Mobile nav items #}
      <div class="flex md:hidden items-center gap-2">
        <a
          href="{{ '/pages/contact/' | url }}"
          class="px-3 py-1.5 text-xs font-medium tracking-wide uppercase bg-[#DBA20D] text-[#31272d] rounded-md hover:opacity-90 transition-opacity whitespace-nowrap"
        >
          Contact
        </a>
        <a
          href="https://monicagrey.clientsecure.me/sign-in"
          class="px-3 py-1.5 text-xs font-medium tracking-wide uppercase text-white/50 border border-white/20 rounded-md hover:text-white/80 hover:border-white/40 transition-colors whitespace-nowrap"
          target="_blank"
          rel="noopener noreferrer"
        >
          Login
        </a>
        <button
          type="button"
          class="flex items-center justify-center w-9 h-9 text-white/70 hover:text-white transition-colors rounded-md hover:bg-white/8"
          aria-label="Open menu"
          aria-expanded="false"
          data-mobile-toggle
        >
          <svg class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" data-mobile-open-icon>
            <path fill-rule="evenodd" d="M2 4.75A.75.75 0 0 1 2.75 4h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 4.75ZM2 10a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 10Zm0 5.25a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd" />
          </svg>
          <svg class="w-5 h-5 hidden" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" data-mobile-close-icon>
            <path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
          </svg>
        </button>
      </div>
    </nav>

    {# Mobile dropdown menu #}
    <div class="hidden md:hidden border-t border-white/10" data-mobile-menu>
      <ul class="py-2 px-4">
        <li>
          <a href="{{ '/pages/about/' | url }}" class="block py-3 text-sm text-white/70 hover:text-white transition-colors border-b border-white/5">About</a>
        </li>
        <li>
          <a href="{{ '/pages/services/' | url }}" class="block py-3 text-sm text-white/70 hover:text-white transition-colors border-b border-white/5">What We Treat</a>
        </li>
        <li>
          <a href="{{ '/pages/how-we-work/' | url }}" class="block py-3 text-sm text-white/70 hover:text-white transition-colors border-b border-white/5">How We Work</a>
        </li>
        <li>
          <a href="{{ '/pages/groups/' | url }}" class="block py-3 text-sm text-white/70 hover:text-white transition-colors border-b border-white/5">Groups</a>
        </li>
        <li>
          <a href="{{ '/pages/investment/' | url }}" class="block py-3 text-sm text-white/70 hover:text-white transition-colors border-b border-white/5">Investment</a>
        </li>
      </ul>
    </div>
  </navigation>

  <script>
    (() => {
      // Mobile: hamburger menu
      const mobileToggle = document.querySelector("[data-mobile-toggle]");
      const mobileMenu = document.querySelector("[data-mobile-menu]");
      const openIcon = document.querySelector("[data-mobile-open-icon]");
      const closeIcon = document.querySelector("[data-mobile-close-icon]");
      if (mobileToggle && mobileMenu) {
        mobileToggle.addEventListener("click", () => {
          const isOpen = !mobileMenu.classList.contains("hidden");
          mobileMenu.classList.toggle("hidden");
          mobileToggle.setAttribute("aria-expanded", String(!isOpen));
          openIcon.classList.toggle("hidden");
          closeIcon.classList.toggle("hidden");
        });
      }

      // Desktop: Services dropdown
      const dropdown = document.querySelector("[data-dropdown]");
      if (dropdown) {
        const toggle = dropdown.querySelector("[data-dropdown-toggle]");
        const menu = dropdown.querySelector("[data-dropdown-menu]");
        const chevron = dropdown.querySelector("[data-dropdown-chevron]");

        const open = () => {
          menu.classList.remove("hidden");
          toggle.setAttribute("aria-expanded", "true");
          chevron.style.transform = "rotate(180deg)";
        };
        const close = () => {
          menu.classList.add("hidden");
          toggle.setAttribute("aria-expanded", "false");
          chevron.style.transform = "";
        };

        toggle.addEventListener("click", () => {
          menu.classList.contains("hidden") ? open() : close();
        });

        // Close when clicking outside
        document.addEventListener("click", (e) => {
          if (!dropdown.contains(e.target)) close();
        });
      }
    })();
  </script>
{% endblock %}
