{% block navigation %}
  <navigation class="block bg-nav-bg shadow-sm border-b border-border sticky top-0 z-50">
    <nav class="flex items-center h-14 md:h-20 max-w-7xl mx-auto px-4 md:pr-8 md:pl-0">
      <a href="{{ '/' | url }}" class="flex items-center hover:opacity-80 transition-opacity shrink-0">
        {# Mobile: icon only #}
        <img src="{{ '/assets/img/logo-small.png' | url }}" alt="Grey Wellness logo" class="h-10 w-auto md:hidden" loading="lazy" decoding="async" />
        {# Desktop: full logo #}
        <img src="{{ '/assets/img/logo.png' | url }}" alt="Grey Wellness logo" class="h-34 w-auto hidden md:block" loading="lazy" decoding="async" />
      </a>
      <div class="flex-1"></div>

      {# Desktop nav items #}
      <div class="hidden md:flex items-center gap-8">
        {% for page in collections.pages %}
          {% if page.fileSlug != "contact" and not page.data.hidden_from_nav %}
            <a
              href="{{ page.url | url }}"
              class="text-sm font-medium text-nav-fg/70 hover:text-nav-fg transition-colors tracking-wide uppercase"
            >
              {{ page.data.title or page.fileSlug }}
            </a>
          {% endif %}
        {% endfor %}

        <a
          href="{{ '/pages/contact/' | url }}"
          class="px-4 py-2 text-sm font-medium tracking-wide uppercase bg-primary text-primary-foreground rounded-md hover:opacity-90 transition-opacity"
        >
          Contact
        </a>
        <a
          href="https://monicagrey.clientsecure.me/sign-in"
          class="px-4 py-2 text-sm font-medium tracking-wide uppercase text-nav-fg/50 border border-border rounded-md hover:text-nav-fg hover:border-nav-fg/30 transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          Client Portal
        </a>
      </div>

      {# Mobile nav items #}
      <div class="flex md:hidden items-center gap-2">
        <a
          href="{{ '/pages/contact/' | url }}"
          class="px-3 py-1.5 text-xs font-medium tracking-wide uppercase bg-primary text-primary-foreground rounded-md hover:opacity-90 transition-opacity whitespace-nowrap"
        >
          Contact
        </a>
        <a
          href="https://monicagrey.clientsecure.me/sign-in"
          class="px-3 py-1.5 text-xs font-medium tracking-wide uppercase text-nav-fg/50 border border-border rounded-md hover:text-nav-fg hover:border-nav-fg/30 transition-colors whitespace-nowrap"
          target="_blank"
          rel="noopener noreferrer"
        >
          Login
        </a>
        <button
          type="button"
          class="flex items-center justify-center w-9 h-9 text-nav-fg/70 hover:text-nav-fg transition-colors rounded-md hover:bg-nav-fg/8"
          aria-label="Open menu"
          aria-expanded="false"
          data-mobile-toggle
        >
          <svg class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" data-mobile-open-icon>
            <path fill-rule="evenodd" d="M2 4.75A.75.75 0 0 1 2.75 4h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 4.75ZM2 10a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 10Zm0 5.25a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd" />
          </svg>
          <svg class="w-5 h-5 hidden" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" data-mobile-close-icon>
            <path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
          </svg>
        </button>
      </div>
    </nav>

    {# Mobile dropdown menu #}
    <div class="hidden md:hidden border-t border-border" data-mobile-menu>
      <ul class="py-2 px-4">
        {% for page in collections.pages %}
          {% if page.fileSlug != "contact" and not page.data.hidden_from_nav %}
            <li>
              <a
                href="{{ page.url | url }}"
                class="block py-3 text-sm text-nav-fg/70 hover:text-nav-fg transition-colors border-b border-border last:border-0"
              >
                {{ page.data.title or page.fileSlug }}
              </a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
  </navigation>

  <script>
    (() => {
      // Mobile: hamburger menu
      const mobileToggle = document.querySelector("[data-mobile-toggle]");
      const mobileMenu = document.querySelector("[data-mobile-menu]");
      const openIcon = document.querySelector("[data-mobile-open-icon]");
      const closeIcon = document.querySelector("[data-mobile-close-icon]");
      if (mobileToggle && mobileMenu) {
        mobileToggle.addEventListener("click", () => {
          const isOpen = !mobileMenu.classList.contains("hidden");
          mobileMenu.classList.toggle("hidden");
          mobileToggle.setAttribute("aria-expanded", String(!isOpen));
          openIcon.classList.toggle("hidden");
          closeIcon.classList.toggle("hidden");
        });
      }
    })();
  </script>
{% endblock %}
