{% from "macros/logo.njk" import logo %}
{% block navigation %}
  {# Resolve locale-specific data for this render #}
  {% set _lang = lang | default("en") %}
  {% set _t = i18n[_lang] %}
  {% set _contactUrl = "/" + _lang + "/pages/contact/" %}
  {% set _homeUrl = "/" + _lang + "/" %}
  {% set _aboutUrl = "/" + _lang + "/pages/about/" %}
  {% set _servicesUrl = "/" + _lang + "/pages/treatment/" %}
  {% set _investmentUrl = "/" + _lang + "/pages/investment/" %}
  {# Language switcher: get alternate locale links for the current page #}
  {% set _langAlternates = page.url | locale_links %}

  <navigation class="block bg-nav-bg shadow-sm border-b border-border sticky top-0 z-50">
    <nav class="flex items-center h-14 md:h-20 max-w-7xl mx-auto px-4 md:pr-8 md:pl-0">
      <a href="{{ _homeUrl | url }}" class="flex items-center ml-4 hover:opacity-80 transition-opacity shrink-0">
        {{ logo() }}
      </a>
      <div class="flex-1"></div>

      {# Desktop nav items #}
      <div class="hidden md:flex items-center gap-6">
        <a href="{{ _aboutUrl | url }}" class="text-sm font-medium text-nav-fg/70 hover:text-nav-fg transition-colors tracking-wide uppercase">
          {{ _t.nav_about }}
        </a>
        <div class="relative" data-dropdown>
          <button
            type="button"
            class="flex items-center gap-1 text-sm font-medium text-nav-fg/70 hover:text-nav-fg transition-colors tracking-wide uppercase"
            aria-expanded="false"
            data-dropdown-toggle
          >
            {{ _t.nav_services }}
            <svg class="w-3.5 h-3.5 mt-0.5 transition-transform" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" data-dropdown-chevron>
              <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
            </svg>
          </button>
          <div class="absolute top-full left-1/2 -translate-x-1/2 mt-2 min-w-max rounded-xl bg-nav-bg border border-border shadow-xl py-1 hidden" data-dropdown-menu>
            <a href="{{ _servicesUrl | url }}" class="block px-4 py-3 text-sm text-nav-fg/70 hover:text-nav-fg hover:bg-nav-fg/5 transition-colors whitespace-nowrap">
              {{ _t.nav_services_what_we_treat }}
            </a>
            <a href="{{ "/" + _lang + "/pages/process/" | url }}" class="block px-4 py-3 text-sm text-nav-fg/70 hover:text-nav-fg hover:bg-nav-fg/5 transition-colors whitespace-nowrap">
              {{ _t.nav_services_how_we_work }}
            </a>
            <a href="{{ "/" + _lang + "/pages/groups/" | url }}" class="block px-4 py-3 text-sm text-nav-fg/70 hover:text-nav-fg hover:bg-nav-fg/5 transition-colors whitespace-nowrap">
              {{ _t.nav_services_groups }}
            </a>
          </div>
        </div>

        <a href="{{ _investmentUrl | url }}" class="text-sm font-medium text-nav-fg/70 hover:text-nav-fg transition-colors tracking-wide uppercase">
          {{ _t.nav_investment }}
        </a>

        <a
          href="{{ _contactUrl | url }}"
          class="px-4 py-2 text-sm font-medium tracking-wide uppercase bg-primary text-primary-foreground rounded-md hover:opacity-90 transition-opacity"
        >
          {{ _t.nav_contact }}
        </a>

        <a
          href="https://monicagrey.clientsecure.me/sign-in"
          class="px-4 py-2 text-sm font-medium tracking-wide uppercase text-nav-fg/50 border border-border rounded-md hover:text-nav-fg hover:border-nav-fg/30 transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          {{ _t.nav_client_portal }}
        </a>

        {# Language switcher #}
        {% if _langAlternates.length %}
          <div class="flex items-center gap-1 border-l border-nav-fg/20 pl-4">
            <span class="text-xs font-bold text-nav-fg uppercase tracking-wider">{{ _lang | upper }}</span>
            {% for _alt in _langAlternates %}
            <span class="text-nav-fg/30 text-xs">|</span>
            <a
              href="{{ _alt.url | url }}"
              hreflang="{{ _alt.lang }}"
              class="text-xs font-bold text-nav-fg/50 uppercase tracking-wider hover:text-nav-fg transition-colors"
              aria-label="{{ _t.lang_other_label }}"
            >{{ _alt.lang | upper }}</a>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      {# Mobile nav items: language switcher + hamburger only #}
      <div class="flex md:hidden items-center gap-2">
        {% if _langAlternates.length %}
          {% for _alt in _langAlternates %}
          <a
            href="{{ _alt.url | url }}"
            hreflang="{{ _alt.lang }}"
            class="px-2 py-1 text-xs font-bold text-nav-fg/50 uppercase tracking-wider border border-border rounded hover:text-nav-fg hover:border-nav-fg/40 transition-colors"
            aria-label="{{ _t.lang_other_label }}"
          >{{ _alt.lang | upper }}</a>
          {% endfor %}
        {% endif %}
        <button
          type="button"
          class="flex items-center justify-center w-9 h-9 text-nav-fg/70 hover:text-nav-fg transition-colors rounded-md hover:bg-nav-fg/8"
          aria-label="Open menu"
          aria-expanded="false"
          data-mobile-toggle
        >
          <svg class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" data-mobile-open-icon>
            <path fill-rule="evenodd" d="M2 4.75A.75.75 0 0 1 2.75 4h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 4.75ZM2 10a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 10Zm0 5.25a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75a.75.75 0 0 1-.75-.75Z" clip-rule="evenodd" />
          </svg>
          <svg class="w-5 h-5 hidden" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" data-mobile-close-icon>
            <path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
          </svg>
        </button>
      </div>
    </nav>

    {# Mobile dropdown menu — mirrors desktop structure #}
    <div class="hidden md:hidden border-t border-border bg-nav-bg shadow-lg" data-mobile-menu>
      <ul class="py-2 px-4">
        <li>
          <a href="{{ _aboutUrl | url }}" class="block py-3 text-sm font-medium text-nav-fg/70 hover:text-nav-fg transition-colors border-b border-border tracking-wide uppercase">
            {{ _t.nav_about }}
          </a>
        </li>
        <li>
          <button
            type="button"
            class="flex items-center justify-between w-full py-3 text-sm font-medium text-nav-fg/70 hover:text-nav-fg transition-colors border-b border-border tracking-wide uppercase"
            aria-expanded="false"
            data-mobile-services-toggle
          >
            {{ _t.nav_services }}
            <svg class="w-3.5 h-3.5 transition-transform" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" data-mobile-services-chevron>
              <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
            </svg>
          </button>
          <ul class="hidden pl-4" data-mobile-services-menu>
            <li>
              <a href="{{ _servicesUrl | url }}" class="block py-2.5 text-sm text-nav-fg/70 hover:text-nav-fg transition-colors border-b border-border">
                {{ _t.nav_services_what_we_treat }}
              </a>
            </li>
            <li>
              <a href="{{ "/" + _lang + "/pages/process/" | url }}" class="block py-2.5 text-sm text-nav-fg/70 hover:text-nav-fg transition-colors border-b border-border">
                {{ _t.nav_services_how_we_work }}
              </a>
            </li>
            <li>
              <a href="{{ "/" + _lang + "/pages/groups/" | url }}" class="block py-2.5 text-sm text-nav-fg/70 hover:text-nav-fg transition-colors border-b border-border">
                {{ _t.nav_services_groups }}
              </a>
            </li>
          </ul>
        </li>
        <li>
          <a href="{{ _investmentUrl | url }}" class="block py-3 text-sm font-medium text-nav-fg/70 hover:text-nav-fg transition-colors border-b border-border tracking-wide uppercase">
            {{ _t.nav_investment }}
          </a>
        </li>
        <li>
          <a href="{{ _contactUrl | url }}" class="block py-3 text-sm font-medium text-nav-fg/70 hover:text-nav-fg transition-colors border-b border-border tracking-wide uppercase">
            {{ _t.nav_contact }}
          </a>
        </li>
        <li>
          <a
            href="https://monicagrey.clientsecure.me/sign-in"
            class="block py-3 text-sm font-medium text-nav-fg/50 hover:text-nav-fg transition-colors tracking-wide uppercase"
            target="_blank"
            rel="noopener noreferrer"
          >
            {{ _t.nav_client_portal }}
          </a>
        </li>
      </ul>
    </div>
  </navigation>

  <script>
    (() => {
      // Mobile: hamburger menu
      const mobileToggle = document.querySelector("[data-mobile-toggle]");
      const mobileMenu = document.querySelector("[data-mobile-menu]");
      const openIcon = document.querySelector("[data-mobile-open-icon]");
      const closeIcon = document.querySelector("[data-mobile-close-icon]");
      if (mobileToggle && mobileMenu) {
        mobileToggle.addEventListener("click", () => {
          const isOpen = !mobileMenu.classList.contains("hidden");
          mobileMenu.classList.toggle("hidden");
          mobileToggle.setAttribute("aria-expanded", String(!isOpen));
          openIcon.classList.toggle("hidden");
          closeIcon.classList.toggle("hidden");
        });
      }

      // Mobile: Services sub-menu
      const mobileServicesToggle = document.querySelector("[data-mobile-services-toggle]");
      const mobileServicesMenu = document.querySelector("[data-mobile-services-menu]");
      const mobileServicesChevron = document.querySelector("[data-mobile-services-chevron]");
      if (mobileServicesToggle && mobileServicesMenu) {
        mobileServicesToggle.addEventListener("click", () => {
          const isOpen = !mobileServicesMenu.classList.contains("hidden");
          mobileServicesMenu.classList.toggle("hidden");
          mobileServicesToggle.setAttribute("aria-expanded", String(!isOpen));
          if (mobileServicesChevron) {
            mobileServicesChevron.style.transform = isOpen ? "" : "rotate(180deg)";
          }
        });
      }

      // Desktop: Services dropdown
      const dropdown = document.querySelector("[data-dropdown]");
      if (dropdown) {
        const toggle = dropdown.querySelector("[data-dropdown-toggle]");
        const menu = dropdown.querySelector("[data-dropdown-menu]");
        const chevron = dropdown.querySelector("[data-dropdown-chevron]");

        const open = () => {
          menu.classList.remove("hidden");
          toggle.setAttribute("aria-expanded", "true");
          chevron.style.transform = "rotate(180deg)";
        };
        const close = () => {
          menu.classList.add("hidden");
          toggle.setAttribute("aria-expanded", "false");
          chevron.style.transform = "";
        };

        toggle.addEventListener("click", () => {
          menu.classList.contains("hidden") ? open() : close();
        });

        document.addEventListener("click", (e) => {
          if (!dropdown.contains(e.target)) close();
        });
      }
    })();
  </script>
{% endblock %}
