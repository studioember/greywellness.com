{% extends 'layouts/base.njk' %}

{% block content %}

{{ content | safe }}

{% if collections[page.url] is defined %}
  <h2 class="text-2xl font-bold mb-4">Recent Posts</h2>
{% else %}
  <h2 class="text-2xl font-bold mb-4">No Posts Found</h2>
{% endif %}

<ul>
{% set key = page.url %}
{%- for post in collections[key] -%}
  <li>
    <a href="{{ post.url | url }}">{{ post.data.title }}</a>
    <div>{{ post.date | dateSimple }}</div>
  </li>
{%- endfor -%}
</ul>
{% endblock %}
