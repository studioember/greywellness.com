<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    {# ── Page title ── #}
    {% if meta_title %}
      {% set _page_title = meta_title %}
    {% elif title %}
      {% set _page_title = title ~ " · " ~ site.name %}
    {% else %}
      {% set _page_title = site.name %}
    {% endif %}
    {% set _page_desc = description or site.description %}
    {% set _page_url  = site.url ~ page.url %}
    {% set _og_image  = site.url ~ "/assets/img/og-image.jpg" %}

    <title>{{ _page_title }}</title>

    {# ── Core SEO ── #}
    <meta name="description" content="{{ _page_desc }}">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="{{ _page_url }}">

    {# ── Open Graph ── #}
    <meta property="og:type"        content="{{ og_type or 'website' }}">
    <meta property="og:url"         content="{{ _page_url }}">
    <meta property="og:title"       content="{{ _page_title }}">
    <meta property="og:description" content="{{ _page_desc }}">
    <meta property="og:image"       content="{{ _og_image }}">
    <meta property="og:site_name"   content="{{ site.name }}">
    <meta property="og:locale"      content="en_US">
    <meta property="og:locale:alternate" content="es_ES">

    {# ── Twitter Card ── #}
    <meta name="twitter:card"        content="summary_large_image">
    <meta name="twitter:title"       content="{{ _page_title }}">
    <meta name="twitter:description" content="{{ _page_desc }}">
    <meta name="twitter:image"       content="{{ _og_image }}">

    <link rel="icon" type="image/png" sizes="32x32" href="{{ '/assets/favicon/favicon-32x32.png' | url }}">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ '/assets/favicon/favicon-16x16.png' | url }}">
    <link rel="apple-touch-icon" sizes="180x180" href="{{ '/assets/favicon/apple-touch-icon.png' | url }}">
    <link rel="manifest" href="{{ '/assets/favicon/site.webmanifest' | url }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <!--Fonts-->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;900&family=Nunito:wght@300;400;500;600;700;900&display=swap">

    <!-- Color Scheme -->
    <script>
      (() => {
        const root = document.documentElement;
        const media = window.matchMedia("(prefers-color-scheme: dark)");
        const applyTheme = () => {
          const theme = media.matches ? "dark" : "light";
          root.dataset.theme = theme;
          root.style.colorScheme = theme;
        };

        applyTheme();
        media.addEventListener("change", applyTheme);
      })();
    </script>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-4B4KP12KBL"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-4B4KP12KBL');
    </script>

    <!-- Style Sheets -->
    <link rel="stylesheet" href="{{ '/assets/css/generated/tailwind.css' | url }}">
    <link rel="stylesheet" href="{{ '/assets/css/theme/theme.css' | url }}">
  </head>

  <body class="bg-background text-foreground antialiased">
    {# Navigation - Start #}
    {% block navigation %}
    {% include 'components/navigation.njk' %}
    {% endblock %}
    {# Navigation - End #}

    {% if full_width %}
    <main id="content" class="mx-auto px-4 sm:px-6 py-10">
    {% else %}
    <main id="content" class="mx-auto max-w-5xl px-4 sm:px-6 py-10">
    {% endif %}
      {# Title - Start #}
      {% if title and title_hidden != true %}
      <header class="mb-8">
        <h1 class="text-3xl md:text-5xl font-bold tracking-tight">{{ title }}</h1>
        {# Description #}
        {% if description and description_hidden != true %}
          <p class="mt-8 text-muted">{{ description }}</p>
        {% endif %}
        {# Date #}
        {% if date_hidden != true %}
          <p class="text-muted">{{ page.date | dateSimple }}</p>
        {% endif %}
        {# -------- #}
        <hr class="mt-8 border-border">
      </header>
      {% endif %}
      {# Title - End #}

      {# Content - Start #}
      {% block content %}
      {% if no_prose %}
        {{ content | safe }}
      {% else %}
        <article class="prose max-w-none prose-headings:text-foreground prose-p:text-foreground prose-strong:text-foreground prose-a:text-primary prose-hr:border-border prose-blockquote:text-foreground prose-code:text-foreground prose-li:text-foreground prose-th:text-foreground prose-td:text-foreground">
          {{ content | safe }}
        </article>
      {% endif %}
      {% endblock %}
      {# Content - End #}
    </main>

    {# Footer - Start #}
    {% block footer %}
    {% include 'components/footer.njk' %}
    {% endblock %}
    {# Footer - End #}
    <style>
      .sp-schedule-btn {
        display: inline-block;
        padding: 14px 32px;
        color: hsl(var(--primary-foreground)) !important;
        background: hsl(var(--primary));
        border: 0;
        border-radius: 6px;
        font-size: 1rem;
        font-weight: 600;
        text-decoration: none;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        transition: opacity 0.15s;
        cursor: pointer;
      }
      .sp-schedule-btn:hover { opacity: 0.9; }
      .sp-schedule-btn:active { opacity: 0.75; }
    </style>
    <script src="https://widget-cdn.simplepractice.com/assets/integration-1.0.js"></script>
  </body>
</html>
