---
layout: layouts/base.njk
no_prose: true
full_width: true
title_hidden: true
date_hidden: true
---
{% set _lang = lang | default("en") %}
{% set _t = i18n[_lang] %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "MedicalOrganization"],
  "name": "Grey Wellness",
  "description": "{{ site.description }}",
  "url": "{{ site.url }}",
  "priceRange": "$$",
  "founder": {
    "@type": "Person",
    "name": "Mónica Grey",
    "jobTitle": "{{ _t.home_schema_job_title }}",
    "knowsLanguage": ["en", "es"]
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "{{ _t.home_schema_offer_catalog }}",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "{{ _t.home_schema_cbti_name }}",
          "description": "{{ _t.home_schema_cbti_desc }}"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "{{ _t.home_schema_anxiety_name }}",
          "description": "{{ _t.home_schema_anxiety_desc }}"
        }
      }
    ]
  },
  "availableLanguage": [
    { "@type": "Language", "name": "English" },
    { "@type": "Language", "name": "Spanish" }
  ]
}
</script>

<!-- Hero -->
<section class="relative bg-hero overflow-hidden -mx-4 sm:-mx-6 -mt-10">
  <img src="{{ '/assets/img/hero.jpg' | url }}" alt="{{ _t.home_hero_img_alt }}" class="absolute inset-0 w-full h-full object-cover object-center" loading="eager" decoding="async">

  <div class="absolute inset-0" style="background: linear-gradient(to right, hsl(var(--hero-overlay) / 0.92), hsl(var(--hero-overlay) / 0.65), transparent)"></div>

  {# Brand elements E3 (right) and E12 (left) — from brand identity guide #}
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    {# E3 — right side, portrait shape #}
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 332.84 563.61" class="absolute -right-16 top-0 h-80 w-auto md:-right-8 md:h-[560px]" fill="hsl(var(--secondary))" fill-opacity="0.80">
      <path d="M113.79,223.44c30.4-48.8,88.8-83.2,129.6-83.2,22.4,0,31.6,12,31.6,32.4,0,48.4-58.4,76.4-114,76.4-8.8,0-17.6-.4-26-2-8.8,16.4-14.4,32.8-14.4,47.6,0,18,12.8,48,36.4,48,21.2,0,43.6-23.6,57.2-40.4,1.2-2.4,2.4-4.8,4-6.8,4-6.4,10.8-14.8,16.8-14.8,4.4,0,6.8,5.6,6.8,10.4,0,4.4-4,12-5.2,15.6-1.6,4.4-14,30-24,52.4,11.2-7.6,22-14,32.8-20.4,20.38-11.95,33.35-25.75,44.88-40.31l-.09-.1s.38-.38.97-1.02c1.29-1.65,2.57-3.3,3.84-4.97.82-1.1,1.7-2.14,2.68-3.05,9.25-12.48,24.91-38.13,34.33-78.48V80.32C332,35.96,296.04,0,251.67,0s-80.32,35.96-80.32,80.32c0,.26.02.52.02.79-3.65-.51-7.37-.79-11.15-.79-44.36,0-80.32,35.96-80.32,80.32,0,21.46,8.45,40.92,22.16,55.32,3.47,2.87,7.38,5.39,11.74,7.47Z"/>
      <path d="M254.99,173.84c0-7.6-2-13.6-10.8-13.6-31.2,0-74,33.2-100,71.6,3.6.4,7.2.4,11.2.4,42.4,0,99.6-17.2,99.6-58.4Z"/>
      <path d="M121.79,465.44c0,4.8,2.4,6.8,10,6.8,19.2,0,33.2-34.4,46.8-72.8-4.4,3.2-8.8,6-13.6,9.6-18.4,13.2-43.2,44-43.2,56.4Z"/>
      <path d="M312.26,295.65c-18.5,26.89-43.33,48.43-72.31,65.74-5.79,3.46-11.69,6.73-17.68,9.83-6.44,3.33-13.1,6.56-18.23,11.69-6.05,6.05-9.44,14.22-12.45,22.23-6.15,16.39-11.35,33.18-19.06,48.89-6.5,13.25-15.12,25.99-27.53,33.98-12.48,8.04-31.71,9.25-40.08-3.01-6.57-9.61-3.47-22.73,1.3-33.36,9.73-21.71,25.53-40.65,45.13-54.13,9.93-6.83,20.85-12.31,29.95-20.21,9.11-7.9,16.46-19.02,16.06-31.07-22.74,19.62-60.48,18.53-82.06-2.36-12.64-12.24-19.47-29.69-20.88-47.22-1.41-17.53,2.26-35.18,8.27-51.71.73-2.02,1.51-4.23.82-6.26-.42-1.23-1.32-2.22-2.22-3.15-5.62-5.83-12.31-10.97-20.14-13.05-7.78-2.06-16.09-.93-23.8,1.38-26.25,7.86-47.73,30.02-54.77,56.51-7.04,26.48.61,56.38,19.5,76.24,18.89,19.85,48.37,28.98,75.17,23.26-24.46,25.14-29.4,67.05-11.46,97.19,17.94,30.13,57.14,45.77,90.89,36.26,11.6,25.7,36.38,45.34,64.27,49.49,27.89,4.15,57.9-7.91,74.16-30.95,17.45-24.74,17.9-57.23,17.69-87.5,0-59.69-1-119.39-1.22-179.08,0-1.52.11-3.25-.3-4.55-5.23,12.55-11.62,24.17-19.03,34.93Z"/>
    </svg>
    {# E12 — left side, landscape shape #}
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 377.72 339.66" class="absolute -left-10 bottom-0 h-36 w-auto md:h-52" fill="hsl(var(--secondary))" fill-opacity="0.50">
      <path d="M355.32,133.48c-6.93-8.43-15.1-15.55-24.1-21.68-10.7-7.29-20.69-5.57-32.59-1.88-11.86,3.67-22.92,9.9-32.37,17.94-16.57,14.09-28.25,33.37-35.36,53.93-8.88,25.68-12.91,56.45-35.65,71.31-16.99,11.11-41.69,8.4-55.87-6.13-12.79-13.11-16.18-32.47-18.95-50.58-11.33,13.78-26.66,28.14-44.27,25.34-10.61-1.68-19.47-9.69-24.37-19.26-4.9-9.57-6.32-20.54-6.54-31.29-.88-42.82,16-84.71,13.8-127.49-.56-10.92-2.54-22.19-8.85-31.11C43.87,3.67,32.31-2.24,21.81.81,13.26,3.3,7.1,11.14,4.25,19.58c-2.85,8.44-2.92,17.53-2.95,26.44-.43,97.88-.86,195.76-1.3,293.64h293.57c-1.3-21.51-9.64-42.64-24.44-58.35,43.24,8.59,90.71-19.12,104.48-61,2.98-9.07,4.29-18.56,4.11-28.04-.4-21.34-8.78-42.23-22.39-58.79Z"/>
    </svg>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 sm:px-10 py-32 md:py-44">
    <div class="max-w-xl">
      <p class="text-primary text-sm font-semibold tracking-widest uppercase mb-4">Mónica Grey, LCPC</p>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-white leading-tight mb-6">
        {{ _t.home_hero_h1_line1 }}<br>
        {{ _t.home_hero_h1_line2 }}
      </h1>
      <p class="text-white/70 text-lg md:text-xl leading-relaxed mb-10">
        {{ _t.home_hero_subtitle }}
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <div>{% scheduleButton _t.home_hero_cta_schedule %}</div>
        <a
          href="{{ '/' + _lang + '/pages/treatment/' }}"
          class="inline-block px-6 py-3.5 text-sm font-semibold tracking-wide uppercase text-white border border-white/30 rounded-md hover:bg-white/10 transition-colors text-center"
        >
          {{ _t.home_hero_cta_services }}
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Wave: Hero → Services -->
<div class="wave-divider -mt-16 relative z-10 overflow-hidden -mx-4 sm:-mx-6" aria-hidden="true">
  <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="block w-full h-16">
    <path d="M0,40 C240,80 480,0 720,40 C960,80 1200,10 1440,40 L1440,80 L0,80 Z" class="wave-bg" />
  </svg>
</div>

<!-- Services -->
<section class="py-20 px-4 sm:px-6 max-w-7xl mx-auto">
  <div class="mb-12 text-center">
    <p class="text-primary text-sm font-semibold tracking-widest uppercase mb-3">{{ _t.home_services_eyebrow }}</p>
    <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground">{{ _t.home_services_heading }}</h2>
    <p class="mt-4 text-muted text-lg max-w-2xl mx-auto">
      {{ _t.home_services_subtitle }}
    </p>
  </div>

  <div class="grid sm:grid-cols-2 gap-6">
    <div class="group relative bg-card rounded-2xl p-8 shadow-sm border border-border hover:shadow-md transition-all duration-200 overflow-hidden">
      <a href="{{ '/' + _lang + '/pages/sleep/' | url }}" class="absolute inset-0 z-10" aria-label="{{ _t.home_sleep_aria }}"></a>
      <div class="absolute top-0 left-0 right-0 h-1.5 bg-primary"></div>
      <div class="mb-4"><span class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-primary/15 text-2xl">🌙</span></div>
      <h3 class="text-xl font-bold text-foreground mb-3">{{ _t.home_sleep_title }}</h3>
      <p class="text-muted leading-relaxed mb-5">{{ _t.home_sleep_desc }}</p>
      <span class="text-primary text-sm font-semibold tracking-wide group-hover:underline">{{ _t.home_learn_more }}</span>
    </div>
    <div class="group relative bg-card rounded-2xl p-8 shadow-sm border border-border hover:shadow-md transition-all duration-200 overflow-hidden">
      <a href="{{ '/' + _lang + '/pages/trauma/' | url }}" class="absolute inset-0 z-10" aria-label="{{ _t.home_trauma_aria }}"></a>
      <div class="absolute top-0 left-0 right-0 h-1.5 bg-accent"></div>
      <div class="mb-4"><span class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-accent/30 text-2xl">🤝</span></div>
      <h3 class="text-xl font-bold text-foreground mb-3">{{ _t.home_trauma_title }}</h3>
      <p class="text-muted leading-relaxed mb-5">{{ _t.home_trauma_desc }}</p>
      <span class="text-sm font-semibold tracking-wide group-hover:underline" style="color: hsl(340 35% 50%)">{{ _t.home_learn_more }}</span>
    </div>
    <div class="group relative bg-card rounded-2xl p-8 shadow-sm border border-border hover:shadow-md transition-all duration-200 overflow-hidden">
      <a href="{{ '/' + _lang + '/pages/childhood-experiences/' | url }}" class="absolute inset-0 z-10" aria-label="{{ _t.home_cae_aria }}"></a>
      <div class="absolute top-0 left-0 right-0 h-1.5 bg-secondary"></div>
      <div class="mb-4"><span class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-secondary/20 text-2xl">🌱</span></div>
      <h3 class="text-xl font-bold text-foreground mb-3">{{ _t.home_cae_title }}</h3>
      <p class="text-muted leading-relaxed mb-5">{{ _t.home_cae_desc }}</p>
      <span class="text-sm font-semibold tracking-wide group-hover:underline" style="color: hsl(271 30% 50%)">{{ _t.home_learn_more }}</span>
    </div>
    <div class="group relative bg-card rounded-2xl p-8 shadow-sm border border-border hover:shadow-md transition-all duration-200 overflow-hidden">
      <a href="{{ '/' + _lang + '/pages/stress/' | url }}" class="absolute inset-0 z-10" aria-label="{{ _t.home_stress_aria }}"></a>
      <div class="absolute top-0 left-0 right-0 h-1.5 bg-sage"></div>
      <div class="mb-4"><span class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-sage/15 text-2xl">⚖️</span></div>
      <h3 class="text-xl font-bold text-foreground mb-3">{{ _t.home_stress_title }}</h3>
      <p class="text-muted leading-relaxed mb-5">{{ _t.home_stress_desc }}</p>
      <span class="text-sage text-sm font-semibold tracking-wide group-hover:underline">{{ _t.home_learn_more }}</span>
    </div>
  </div>
</section>

<!-- Wave: Services → Values -->
<div class="wave-divider -mt-16 relative z-10 overflow-hidden -mx-4 sm:-mx-6" aria-hidden="true">
  <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="block w-full h-16">
    <path d="M0,40 C240,0 480,80 720,40 C960,0 1200,70 1440,40 L1440,80 L0,80 Z" style="fill: hsl(var(--accent) / 0.05)" />
  </svg>
</div>

<!-- Inclusion & Values -->
<section class="py-20 px-4 sm:px-6 -mx-4 sm:-mx-6 bg-accent/5">
  <div class="max-w-7xl mx-auto">
    <div class="mb-12 text-center">
      <p class="text-primary text-sm font-semibold tracking-widest uppercase mb-3">{{ _t.home_values_eyebrow }}</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground">{{ _t.home_values_heading }}</h2>
    </div>
    <div class="max-w-3xl mx-auto">
      <div class="bg-card rounded-2xl p-8 md:p-12 shadow-sm border border-border">
        <div class="mb-4"><span class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-primary/15 text-2xl">🌍</span></div>
        <h3 class="text-xl font-bold text-foreground mb-4">{{ _t.home_values_card_title }}</h3>
        <p class="text-muted leading-relaxed mb-4">{{ _t.home_values_p1 }}</p>
        <p class="text-muted leading-relaxed mb-4">{{ _t.home_values_p2 }}</p>
        <p class="text-muted leading-relaxed mb-4">{{ _t.home_values_p3 }}</p>
        <p class="text-muted leading-relaxed mb-4">{{ _t.home_values_p4 }}</p>
        <p class="text-muted leading-relaxed">{{ _t.home_values_p5 }}</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA Banner -->
<section class="cta-banner bg-surface-warm -mx-4 sm:-mx-6 -mb-10">
  <!-- Wave at top of CTA -->
  <div class="wave-divider -mt-16 relative z-10 overflow-hidden" aria-hidden="true">
    <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="block w-full h-16">
      <rect width="1440" height="80" style="fill: hsl(var(--accent) / 0.05)" />
      <path d="M0,50 C360,10 720,70 1080,30 C1260,10 1380,50 1440,40 L1440,80 L0,80 Z" class="wave-surface-warm" />
    </svg>
  </div>
  <div class="pt-8 pb-16 px-4 max-w-2xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-4">{{ _t.home_cta_heading }}</h2>
    <p class="text-muted text-lg mb-8">{{ _t.home_cta_subtitle }}</p>
    <div class="flex flex-col sm:flex-row justify-center gap-4">
      {% scheduleButton _t.home_cta_schedule %}
    </div>
  </div>
  <!-- Wave: CTA bottom → Footer -->
  <div class="wave-divider overflow-hidden" aria-hidden="true">
    <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="block w-full h-12">
      <rect width="1440" height="80" class="wave-surface" />
      <path d="M0,20 C360,60 720,0 1080,40 C1260,60 1380,20 1440,30 L1440,0 L0,0 Z" class="wave-surface-warm" />
    </svg>
  </div>
  <!-- Spacer: covers main's pb-10 so no body-bg bleeds between CTA and footer -->
  <div class="bg-surface h-10" aria-hidden="true"></div>
</section>
